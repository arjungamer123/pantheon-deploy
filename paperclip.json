{
  "$meta": {
    "version": 1
  },
  "database": {
    "mode": "embedded-postgres",
    "embeddedPostgresDataDir": "/paperclip/db",
    "embeddedPostgresPort": 54329,
    "backup": {
      "enabled": true,
      "intervalMinutes": 60,
      "retentionDays": 30,
      "dir": "/paperclip/backups"
    }
  },
  "logging": {
    "mode": "file",
    "logDir": "/paperclip/logs"
  },
  "server": {
    "deploymentMode": "authenticated",
    "exposure": "public",
    "host": "0.0.0.0",
    "port": 3100,
    "serveUi": true,
    "allowedHostnames": ["paperclip-production-a12b.up.railway.app"]
  },
  "auth": {
    "baseUrlMode": "explicit",
    "publicBaseUrl": "https://paperclip-production-a12b.up.railway.app",
    "disableSignUp": false
  },
  "telemetry": {
    "enabled": false
  },
  "storage": {
    "provider": "local_disk",
    "localDisk": {
      "baseDir": "/paperclip/storage"
    },
    "s3": {
      "bucket": "paperclip",
      "region": "us-east-1",
      "prefix": "",
      "forcePathStyle": false
    }
  },
  "secrets": {
    "provider": "local_encrypted",
    "strictMode": false,
    "localEncrypted": {
      "keyFilePath": "/paperclip/secrets/master.key"
    }
  }
}
